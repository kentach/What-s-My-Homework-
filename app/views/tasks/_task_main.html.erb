<div class="homework-show-body">

  <% done = @tasks.count { |t| current_user.completed?(t) } %>
  <% total = @tasks.size %>

  <div class="show-summary-row">

    <div class="show-summary-card">
      <span class="show-summary-num" id="showDoneCount">
        <%= done %>
      </span>
      <span class="show-summary-label">完了</span>
    </div>

    <div class="show-summary-card">
      <span class="show-summary-num" id="showTotalCount">
        <%= total %>
      </span>
      <span class="show-summary-label">合計</span>
    </div>

    <div class="show-summary-msg" id="showProgressMsg">
      <% if total.zero? %>
        タスクがありません
      <% elsif done == total %>
        全部完了！よく頑張ったね
      <% else %>
        一つずつこなしていこう！
      <% end %>
    </div>

  </div>

  <!-- タブ -->
    <div class="task-index-tabs">
      <button class="task-index-tab active" data-tab="all">すべて</button>
      <button class="task-index-tab" data-tab="incomplete">未完了</button>
      <button class="task-index-tab" data-tab="completed">完了</button>
    </div>

  <!-- =========================
      タスク一覧
  ========================= -->
  <div class="task-index-list">
    <div class="task-index-list-header">
      <h3><%= current_user.classroom.eiken_level %> 宿題リスト</h3>
      <span class="task-index-list-count"><%= total %> タスク</span>
    </div>

    <div class="test-index-info">
      <ul>
        <li>📌 授業前に宿題を必ずチェックしよう！</li>
        <li>✅ 宿題が終わったらチェックを入れよう！</li>
      </ul>
    </div>

    <!-- タスク -->
    <% @tasks.each do |task| %>
      <% status = current_user.completed?(task) ? "completed" : "incomplete" %>

      <div id="task-<%= task.id %>"
           class="task-index-<%= 'completed' if status == 'completed' %>"
           data-status="<%= status %>">

        <label class="task-index-check-wrap">

          <div id="completed-button-for-task-<%= task.id %>">
            <%= render "task_completions/completed_button", task: task %>
          </div>

          <span class="task-index-name">
            <%= task.name %>
          </span>

        </label>
      </div>
    <% end %>

  </div>
</div>
