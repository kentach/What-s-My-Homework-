<header class="notification_header">
  <p>Messages from teachers</p>
  <h3>お知らせ <i class="fa-regular fa-comment-dots"></i></h3>
  <div class="notification_filter">
    <%= link_to "すべて", notifications_path,
          class: "notification_filter_btn #{params[:notification_type].blank? ? 'active' : ''}" %>
    <%= link_to "宿題の訂正", notifications_path(notification_type: "correction"),
          class: "notification_filter_btn correction #{params[:notification_type] == 'correction' ? 'active' : ''}" %>
    <%= link_to "月例単語テスト", notifications_path(notification_type: "vocab_monthly_test"),
          class: "notification_filter_btn monthly_test #{params[:notification_type] == 'vocab_monthly_test' ? 'active' : ''}" %>
    <%= link_to "その他", notifications_path(notification_type: "other"),
          class: "notification_filter_btn other #{params[:notification_type] == 'other' ? 'active' : ''}" %>
  </div>
</header>